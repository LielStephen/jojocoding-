{
  "manifest_version": 3,
  "name": "Code Stand",
  "description": "Scan code on the current page and get a precise AI explanation, review, or improvement plan.",
  "version": "1.2.0",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://generativelanguage.googleapis.com/*"],
  "action": {
    "default_title": "Code Stand",
    "default_popup": "index.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
